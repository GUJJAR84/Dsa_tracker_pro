# -----------------------------
# Secrets (DO NOT COMMIT REAL VALUES)
# -----------------------------

# Primary database connection (PostgreSQL)
# Set this to your Neon/PG connection string in local .env or deployment secrets.
DATABASE_URL=REPLACE_WITH_YOUR_DATABASE_URL

# Optional local SQLite path override (usually keep default)
# SQLITE_DB_PATH=tracker.db

# -----------------------------
# Optional app/public URLs
# -----------------------------

# Your deployed app URL (public)
APP_BASE_URL=

# Optional links used in project metadata
GITHUB_REPO_URL=
PROJECT_DEMO_URL=

# -----------------------------
# Optional Streamlit server settings
# -----------------------------
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_SERVER_PORT=8501
